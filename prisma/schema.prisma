// Navagunjara e-commerce Prisma schema.
// Maps exactly to the existing PostgreSQL database (created by Java/Flyway).
// Prisma camelCase <-> PostgreSQL snake_case bridged via @map / @@map.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // NOTE: Prisma 7 — connection URLs are defined in `prisma.config.ts`
  // (datasource.url and migrate.shadowDatabaseUrl/direct). Schema cannot
  // declare `url` / `directUrl` anymore.
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum JewelryType {
  NECKLACE
  RING
  BRACELET
  EARRING
  ANKLET
  BANGLE
  PENDANT
  BROOCH
  OTHER
}

enum ClothingType {
  SAREE
  KURTA
  LEHENGA
  SALWAR_KAMEEZ
  DUPATTA
  SHERWANI
  DHOTI
  BLOUSE
  KURTI
  OTHER
}

enum ClothingSize {
  XS
  S
  M
  L
  XL
  XXL
  XXXL
  FREE_SIZE
}

enum Gender {
  MALE
  FEMALE
  UNISEX
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  UPI
  CARD
  NET_BANKING
  WALLET
  COD
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

// Lifecycle status for a customer account.
// ACTIVE       : normal account, can log in.
// DEACTIVATED  : soft-deleted; cannot log in but all order history is retained.
// ANONYMIZED   : PII scrubbed for GDPR right-to-erasure; orders remain linked
//                to the now-anonymous customer id.
enum CustomerStatus {
  ACTIVE
  DEACTIVATED
  ANONYMIZED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Customer {
  id           BigInt         @id @default(autoincrement())
  firstName    String         @map("first_name") @db.VarChar(255)
  lastName     String         @map("last_name") @db.VarChar(255)
  email        String         @unique @db.VarChar(255)
  phone        String         @db.VarChar(20)
  password     String         @db.VarChar(255)
  addressLine1 String?        @map("address_line1") @db.VarChar(500)
  addressLine2 String?        @map("address_line2") @db.VarChar(500)
  city         String?        @db.VarChar(100)
  state        String?        @db.VarChar(100)
  pincode      String?        @db.VarChar(10)
  country      String         @default("IND") @db.VarChar(3)
  status       CustomerStatus @default(ACTIVE)
  // Incremented on password change / forced logout. Embedded in every issued
  // JWT as `tv`; tokens with a stale value are rejected by api-auth.
  tokenVersion Int            @default(0) @map("token_version")
  deletedAt    DateTime?      @map("deleted_at")
  createdAt    DateTime?      @map("created_at")
  updatedAt    DateTime?      @map("updated_at")
  orders       Order[]
  reviews      Review[]
  wishlist     WishlistItem[]

  @@index([status])
  @@map("customers")
}

model Product {
  id            BigInt         @id @default(autoincrement())
  productType   String         @map("product_type") @db.VarChar(31)
  name          String         @db.VarChar(255)
  description   String?
  price         Decimal        @db.Decimal(12, 2)
  stockQuantity Int            @map("stock_quantity")
  imageUrl      String?        @map("image_url") @db.VarChar(500)
  category      String?        @db.VarChar(50)
  active        Boolean        @default(true)
  createdAt     DateTime?      @map("created_at")
  updatedAt     DateTime?      @map("updated_at")
  jewelry       Jewelry?
  clothing      Clothing?
  orderItems    OrderItem[]
  images        ProductImage[]
  reviews       Review[]
  wishlistItems WishlistItem[]

  @@index([productType])
  @@index([category])
  @@index([active, productType])
  @@map("products")
}

model ProductImage {
  id        BigInt  @id @default(autoincrement())
  productId BigInt  @map("product_id")
  url       String  @db.VarChar(500)
  publicId  String? @map("public_id") @db.VarChar(255)
  alt       String? @db.VarChar(255)
  sortOrder Int     @default(0) @map("sort_order")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
  @@map("product_images")
}

model Jewelry {
  productId     BigInt   @id @map("product_id")
  jewelleryType String?  @map("jewellery_type") @db.VarChar(50)
  material      String?  @db.VarChar(100)
  gemstone      String?  @db.VarChar(100)
  weightGrams   Decimal? @map("weight_grams") @db.Decimal(10, 3)
  caratValue    Float?   @map("carat_value")
  product       Product  @relation(fields: [productId], references: [id])

  @@map("jewelry")
}

model Clothing {
  productId    BigInt  @id @map("product_id")
  clothingType String? @map("clothing_type") @db.VarChar(50)
  size         String? @db.VarChar(10)
  color        String  @db.VarChar(50)
  fabric       String? @db.VarChar(100)
  gender       String? @db.VarChar(20)
  product      Product @relation(fields: [productId], references: [id])

  @@map("clothing")
}

model Order {
  id              BigInt      @id @default(autoincrement())
  customerId      BigInt      @map("customer_id")
  status          String      @default("PENDING") @db.VarChar(30)
  totalAmount     Decimal     @map("total_amount") @db.Decimal(12, 2)
  deliveryAddress String?     @map("delivery_address") @db.VarChar(500)
  deliveryCity    String?     @map("delivery_city") @db.VarChar(100)
  deliveryState   String?     @map("delivery_state") @db.VarChar(100)
  deliveryPincode String?     @map("delivery_pincode") @db.VarChar(10)
  orderedAt       DateTime?   @map("ordered_at")
  updatedAt       DateTime?   @map("updated_at")
  // Restrict: the database refuses to delete a customer who has any order.
  // Customer accounts are never hard-deleted; use status=DEACTIVATED/ANONYMIZED.
  customer        Customer    @relation(fields: [customerId], references: [id], onDelete: Restrict)
  items           OrderItem[]
  payments        Payment[]

  @@index([customerId, orderedAt])
  @@index([status, orderedAt])
  @@map("orders")
}

model OrderItem {
  id        BigInt  @id @default(autoincrement())
  orderId   BigInt  @map("order_id")
  productId BigInt  @map("product_id")
  quantity  Int
  unitPrice Decimal @map("unit_price") @db.Decimal(12, 2)
  subtotal  Decimal @db.Decimal(12, 2)
  // Cascade: deleting an order removes its line items.
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  // Restrict: cannot delete a product that has ever been ordered (history is
  // preserved). Use `active=false` to retire a product instead.
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model Payment {
  id                BigInt    @id @default(autoincrement())
  orderId           BigInt    @map("order_id")
  amount            Decimal   @db.Decimal(12, 2)
  currency          String    @default("INR") @db.VarChar(3)
  method            String    @db.VarChar(30)
  status            String    @default("PENDING") @db.VarChar(30)
  razorpayOrderId   String?   @map("razorpay_order_id") @db.VarChar(100)
  razorpayPaymentId String?   @map("razorpay_payment_id") @db.VarChar(100)
  razorpaySignature String?   @map("razorpay_signature") @db.VarChar(255)
  paypalOrderId     String?   @map("paypal_order_id") @db.VarChar(100)
  paypalCaptureId   String?   @map("paypal_capture_id") @db.VarChar(100)
  transactionId     String?   @map("transaction_id") @db.VarChar(100)
  failureReason     String?   @map("failure_reason") @db.VarChar(500)
  initiatedAt       DateTime? @map("initiated_at")
  completedAt       DateTime? @map("completed_at")
  order             Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, status])
  @@index([razorpayOrderId])
  @@map("payments")
}

model Admin {
  id           BigInt    @id @default(autoincrement())
  firstName    String    @map("first_name") @db.VarChar(255)
  lastName     String    @map("last_name") @db.VarChar(255)
  email        String    @unique @db.VarChar(255)
  password     String    @db.VarChar(255)
  // See Customer.tokenVersion — same purpose, applied to ADMIN tokens.
  tokenVersion Int       @default(0) @map("token_version")
  createdAt    DateTime? @map("created_at")
  updatedAt    DateTime? @map("updated_at")

  @@map("admins")
}

model Review {
  id         BigInt    @id @default(autoincrement())
  productId  BigInt    @map("product_id")
  customerId BigInt    @map("customer_id")
  rating     Int       @db.SmallInt
  title      String?   @db.VarChar(255)
  comment    String?
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  product    Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  // Restrict on customer: review history is preserved for audit even if the
  // account is deactivated. Use anonymization to scrub PII while keeping rows.
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Restrict)

  @@unique([productId, customerId])
  @@index([customerId])
  @@index([productId, createdAt])
  @@map("reviews")
}

model WishlistItem {
  id         BigInt   @id @default(autoincrement())
  customerId BigInt   @map("customer_id")
  productId  BigInt   @map("product_id")
  addedAt    DateTime @default(now()) @map("added_at")
  // Restrict on customer: wishlists are inexpensive to keep and preserving
  // them keeps the customer foreign-key invariants consistent with orders/reviews.
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([customerId, productId])
  @@index([productId])
  @@map("wishlist_items")
}

// ─── Idempotency ─────────────────────────────────────────────────────────────

// Stores response snapshots for client-supplied `Idempotency-Key` headers on
// POST endpoints that create resources (orders, payments). A repeated request
// with the same key + scope + actor returns the original response unchanged,
// so network retries cannot create duplicates.
//
// Entries are GC'd by a periodic job using `expiresAt` (or pruned lazily on
// read). Default TTL is 24h; see services that use it.
model IdempotencyKey {
  // Client-supplied key. Per spec, opaque to the server.
  key            String   @db.VarChar(255)
  // Logical bucket (e.g. "orders.create", "payments.create"). Lets the same
  // key be reused across unrelated endpoints without collision.
  scope          String   @db.VarChar(64)
  // The authenticated actor at the time the key was first seen. Prevents one
  // user from replaying another user's idempotency key.
  actorId        String   @map("actor_id") @db.VarChar(64)
  // Cached HTTP response.
  responseStatus Int      @map("response_status")
  responseBody   String   @map("response_body")
  createdAt      DateTime @default(now()) @map("created_at")
  expiresAt      DateTime @map("expires_at")

  @@id([scope, key])
  @@index([expiresAt])
  @@map("idempotency_keys")
}
