{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": [
    "lib/**/*.ts",
    "services/**/*.ts",
    "types/**/*.ts",
    "hooks/**/*.ts",
    "app/api/**/*.ts"
  ],
  "entryPointStrategy": "expand",
  "out": "docs",
  "name": "Navagunjara API Documentation",
  "readme": "README.md",
  "exclude": [
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/__tests__/**",
    "**/node_modules/**",
    "**/.next/**"
  ],
  "excludeExternals": true,
  "excludePrivate": true,
  "excludeInternal": true,
  "skipErrorChecking": true,
  "tsconfig": "tsconfig.json",
  "blockTags": [
    "@param",
    "@returns",
    "@throws",
    "@module",
    "@author",
    "@organization",
    "@example",
    "@default",
    "@deprecated",
    "@see",
    "@since",
    "@typeParam",
    "@remarks"
  ]
}
