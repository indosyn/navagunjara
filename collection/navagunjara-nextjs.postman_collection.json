      "name": "Auth",
      "item": [
        {
          "name": "Register Customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Customer created', () => {",
                  "  const b = pm.response.json();",
                  "  pm.expect(b.success).to.be.true;",
                  "  pm.expect(b.data).to.have.property('id');",
                  "  pm.collectionVariables.set('customerId', b.data.id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Rahul\",\n  \"lastName\": \"Sharma\",\n  \"email\": \"rahul.sharma@example.com\",\n  \"phone\": \"9876543210\",\n  \"password\": \"Password123!\",\n  \"addressLine1\": \"123 MG Road\",\n  \"city\": \"Bengaluru\",\n  \"state\": \"Karnataka\",\n  \"pincode\": \"560001\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/customers/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "customers", "register"]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Token received', () => {",
                  "  const b = pm.response.json();",
                  "  pm.expect(b.success).to.be.true;",
                  "  pm.expect(b.data.token).to.be.a('string').and.not.empty;",
                  "  pm.collectionVariables.set('token', b.data.token);",
                  "  pm.collectionVariables.set('customerId', b.data.id);",
                  "});"
