{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": ["bom1"],
  "framework": "nextjs",
  "buildCommand": "prisma generate && next build",
  "functions": {
    "app/api/v1/payments/webhook/route.ts": {
      "maxDuration": 30
    },
    "app/api/v1/payments/[id]/confirm/route.ts": {
      "maxDuration": 20
    },
    "app/api/v1/orders/route.ts": {
      "maxDuration": 20
    }
  }
}
