# ─────────────────────────────────────────────────────────────────────────────
# Navagunjara — environment template
#
# Copy to `.env.local` (dev) or set in your platform's secret store (prod).
# Never commit a populated `.env*` file. All values below are placeholders.
#
# Validation happens in `lib/env.ts` at module load. In NODE_ENV=production,
# missing critical values cause a hard boot failure — by design.
# ─────────────────────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development

# Database (required everywhere)
DATABASE_URL=postgresql://user:password@localhost:5432/navagunjara?schema=public

# Auth — generate with: openssl rand -base64 32   (must be >= 32 chars in prod)
NEXTAUTH_SECRET=replace-me-with-32-plus-random-bytes
NEXTAUTH_URL=http://localhost:3000

# Public site URL — used for canonical links, Server Actions allowed origin,
# and email links. In prod set to your https://… domain.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Razorpay (required in prod for live checkout; dev uses test placeholders)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx

# Cloudinary (optional — disables image upload route if absent)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (optional — Resend; order confirmations are skipped if absent)
RESEND_API_KEY=
RESEND_FROM_EMAIL=orders@navagunjara.com

# Rate-limit backend (REQUIRED for multi-instance / serverless prod).
# Without these, the limiter falls back to in-memory and only protects
# within a single process — bots will defeat it across replicas.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Observability
LOG_LEVEL=info

# Seed credentials (used ONLY by `npm run db:seed`)
# In production the seed script refuses to run unless these are set explicitly.
SEED_ADMIN_EMAIL=admin@navagunjara.com
SEED_ADMIN_PASSWORD=
SEED_CUSTOMER_EMAIL=priya@example.com
SEED_CUSTOMER_PASSWORD=
